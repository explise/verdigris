{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "Read",

      "Bash(cargo test *)",
      "Bash(cargo fmt *)",
      "Bash(cargo clippy *)",
      "Bash(cargo check *)",
      "Bash(cargo build *)",
      "Bash(cargo tree *)",
      "Bash(cargo metadata *)",

      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm ci)",
      "Bash(npm ls *)",
      "Bash(node frontend/_verify.js)",

      "Bash(mkdocs build *)",

      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch --list *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git blame *)",
      "Bash(git remote -v)",
      "Bash(git stash list)",

      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh api user)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-edit.sh",
            "timeout": 120,
            "statusMessage": "Running CI gate for the edited path..."
          }
        ]
      }
    ]
  }
}
